# Development/Testing (IP-based, no HTTPS)
http://:80 {
    # Next.js Frontend - default
    handle /api/* {
        reverse_proxy localhost:8000
    }
    
    handle /admin/* {
        reverse_proxy localhost:8000
    }
    
    handle /static/* {
        reverse_proxy localhost:8000
    }
    
    handle {
        reverse_proxy localhost:3000
    }
    
    encode gzip
    
    # Logging
    log {
        output file /var/log/caddy/lorcgr.log
    }
}
